# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
JWT_SECRET=change-me-to-random-64-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://coldmail:changeme@localhost:5432/coldmail
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379

# Encryption (for SMTP/IMAP credentials)
ENCRYPTION_KEY=change-me-to-random-32-bytes-hex
ENCRYPTION_IV_LENGTH=16

# AI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7

# Email
DEFAULT_FROM_NAME=ColdMail.ru
TRACKING_DOMAIN=track.coldmail.ru

# PostgreSQL (Docker Compose)
POSTGRES_PASSWORD=changeme

# Monitoring
GRAFANA_ADMIN_PASSWORD=admin
